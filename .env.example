# J-Quants API
# https://application.jpx-jquants.com/ から取得
JQUANTS_API_KEY=your_jquants_api_key_here

# Anthropic Claude API
# https://console.anthropic.com/ から取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Discord Webhook
# Discordサーバー設定 → 連携サービス → ウェブフック から取得
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# kabu Station API Configuration (フェーズ5で使用)
# KABU_API_URL=http://localhost:18080/kabusapi
# KABU_API_PASSWORD=your_api_password
